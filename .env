# ─────────────────────────────────────────────────────────────────
#  HORMONITAS — variables de entorno (production / Docker)
#  Este archivo SE COMMITEA al repo (privado). En el VPS, solo
#  hay que git pull y docker compose up — sin edición manual.
#
#  Para overrides locales (development), crear .env.local
#  (gitignored, prevalece sobre .env).
# ─────────────────────────────────────────────────────────────────

# ── Base de datos ────────────────────────────────────────────────
# Hostname `db` resuelve al servicio postgres dentro de la red de
# Docker (definido en docker-compose.yml).
DATABASE_URL=postgresql://hormonitas:hormonitas123@db:5432/hormonitas

# Variables que consume el servicio `db` para inicializar postgres
POSTGRES_USER=hormonitas
POSTGRES_PASSWORD=hormonitas123
POSTGRES_DB=hormonitas

# ── Módulo Lectura ───────────────────────────────────────────────
# Mejora la quota de búsquedas en Google Books (opcional)
GOOGLE_BOOKS_API_KEY=AIzaSyDWBPJiqOgoMopHpkZA6Aol_dqDqmKilGE

# ── Push notifications (Web Push) ────────────────────────────────
# VAPID keys generadas con `npx web-push generate-vapid-keys`.
# Si las cambiás, todas las subscriptions existentes se invalidan
# y hay que volver a aceptar el permiso desde cada celular.
VAPID_PUBLIC_KEY=BNaP6CZ_fZerpydegSfnVp8CXEfB3_PajTHcPFrjLCG7KJ7eYorIvE8ECDsZnFDha9VDpJbOabKhwQ91AFiufJ4
VAPID_PRIVATE_KEY=1GEJV2rBIlN3nZrdXT9u9WeLMG80p6A2KrReht41frw
VAPID_SUBJECT=mailto:rpayerodev@gmail.com

# Secret para autenticar /api/push/test y /api/push/cron.
# Cualquier string aleatorio sirve.
PUSH_ADMIN_SECRET=hormonitas-prod-secret-2026-change-me-or-not

# ── Runtime ──────────────────────────────────────────────────────
NODE_ENV=production
